---
// Contact — the closing beat (design-brief.md §8). Bright paper after the
// dark Journal chapter: optimistic, forward-looking, generous whitespace.
// The form is front-end only, wired to Formspree via @formspree/ajax
// (inline success/error, button disabled while submitting). The action/method
// attributes stay as a no-JS fallback: without JavaScript the form still
// submits as a plain HTML POST to the same endpoint.

const LINKS = [
  { label: "GitHub", href: "https://github.com/rolpppp", meta: "github.com/rolpppp" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/rolf-genree-garces-6643552b2/", meta: "linkedin.com/in/rolf-genree-garces" },
  { label: "Email", href: "mailto:rlgarces@up.edu.ph", meta: "rlgarces@up.edu.ph" },
  { label: "Résumé", href: "/Rolf-Garces-Resume.pdf", meta: "PDF · one page" },
];

const FORM_ID = "xrewyney";
const FORM_ENDPOINT = `https://formspree.io/f/${FORM_ID}`;
---

<section id="contact" class="relative bg-paper px-6 pt-32 pb-16 md:px-12 md:pt-44 lg:px-20">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-16 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-7">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-ink/70">
          Next Expedition · Open
        </p>
        <h2 class="mt-6 max-w-2xl font-display text-[clamp(2.75rem,7vw,5.5rem)] leading-[0.95] font-light tracking-tight text-ink">
          Ready to build something meaningful?
        </h2>
        <p class="mt-8 max-w-xl font-sans text-base leading-relaxed text-ink/80 md:text-lg">
          I'm looking for engineering roles, research collaborations, and
          people building things worth navigating toward. If that's you,
          the route is open.
        </p>

        <ul class="mt-12 space-y-1 border-t border-ink/10">
          {LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="group grid grid-cols-[7rem_1fr_auto] items-baseline gap-4 border-b border-ink/10 py-4 transition-colors hover:border-ink/30"
                {...(link.href.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              >
                <span class="font-display text-lg font-light tracking-tight text-ink transition-colors group-hover:text-ocean md:text-xl">
                  {link.label}
                </span>
                <span class="truncate font-mono text-[11px] tracking-[0.12em] text-ink/50 uppercase">
                  {link.meta}
                </span>
                <span class="font-mono text-ink/40 transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-5">
        <form
          id="contact-form"
          action={FORM_ENDPOINT}
          method="POST"
          class="rounded-sm border border-ink/10 bg-paper-alt/50 p-6 md:p-8"
        >
          <p class="font-mono text-[11px] tracking-[0.2em] text-ink/60 uppercase">
            Send a signal
          </p>

          <div data-fs-success role="status" aria-live="polite" class="mt-4 empty:hidden font-sans text-sm leading-relaxed text-ink"></div>
          <div data-fs-error aria-live="polite" class="mt-4 empty:hidden font-sans text-sm leading-relaxed text-ocean"></div>

          <div class="mt-6 space-y-5">
            <div>
              <label for="contact-name" class="block font-sans text-sm font-medium text-ink">Name</label>
              <input
                id="contact-name"
                type="text"
                name="name"
                required
                autocomplete="name"
                data-fs-field
                class="mt-2 w-full rounded-sm border border-ink/20 bg-paper px-3.5 py-2.5 font-sans text-sm text-ink placeholder:text-ink/35 focus:border-ocean focus:outline focus:outline-1 focus:outline-ocean aria-[invalid=true]:border-ocean"
                placeholder="Your name"
              />
              <span data-fs-error="name" class="mt-1.5 block empty:hidden font-sans text-xs text-ocean"></span>
            </div>
            <div>
              <label for="contact-email" class="block font-sans text-sm font-medium text-ink">Email</label>
              <input
                id="contact-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                data-fs-field
                class="mt-2 w-full rounded-sm border border-ink/20 bg-paper px-3.5 py-2.5 font-sans text-sm text-ink placeholder:text-ink/35 focus:border-ocean focus:outline focus:outline-1 focus:outline-ocean aria-[invalid=true]:border-ocean"
                placeholder="you@company.com"
              />
              <span data-fs-error="email" class="mt-1.5 block empty:hidden font-sans text-xs text-ocean"></span>
            </div>
            <div>
              <label for="contact-message" class="block font-sans text-sm font-medium text-ink">Message</label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="5"
                data-fs-field
                class="mt-2 w-full resize-y rounded-sm border border-ink/20 bg-paper px-3.5 py-2.5 font-sans text-sm text-ink placeholder:text-ink/35 focus:border-ocean focus:outline focus:outline-1 focus:outline-ocean aria-[invalid=true]:border-ocean"
                placeholder="What are we building?"></textarea>
              <span data-fs-error="message" class="mt-1.5 block empty:hidden font-sans text-xs text-ocean"></span>
            </div>
          </div>

          {/* Formspree honeypot — invisible to people, catches naive bots. */}
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <button
            type="submit"
            data-fs-submit-btn
            class="mt-7 inline-flex w-full items-center justify-center rounded-sm bg-ocean px-7 py-3.5 font-sans text-sm font-medium tracking-wide text-paper transition-colors hover:bg-ink disabled:cursor-not-allowed disabled:opacity-60"
          >
            Send message
          </button>
        </form>
      </div>
    </div>
  </div>

  <footer class="mx-auto mt-28 max-w-6xl border-t border-ink/10 pt-8 pb-2 md:mt-36">
    <div class="flex flex-wrap items-baseline justify-between gap-4">
      <p class="font-mono text-[11px] tracking-[0.2em] text-ink/50 uppercase">
        Still exploring.
      </p>
      <p class="font-mono text-[11px] tracking-[0.2em] text-ink/40 uppercase">
        11.2543°N · 125.0000°E — Tacloban City
      </p>
    </div>
  </footer>
</section>

<script>
  import { initForm } from "@formspree/ajax";

  // AJAX submission with inline success/error; the form's action/method
  // remain as the no-JS fallback (plain POST to the same endpoint).
  initForm({ formElement: "#contact-form", formId: "xrewyney" });
</script>
