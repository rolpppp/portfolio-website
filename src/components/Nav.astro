---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/',         label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog',     label: 'Blog' },
  { href: '/about',    label: 'About' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="nav-dock" aria-label="Primary navigation">
  {links.map(link => (
    <a
      href={link.href}
      class:list={['nav-link', { active: isActive(link.href) }]}
    >
      {link.label}
    </a>
  ))}
</nav>

<style>
  .nav-dock {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.125rem;
    background: rgba(53, 52, 58, 0.45);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 9999px;
    padding: 0.4rem 0.6rem;
    z-index: 100;
    /* Ghost border — barely perceptible */
    border: 1px solid rgba(66, 72, 68, 0.15);
  }

  .nav-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: #c1c8c3;
    padding: 0.45rem 1rem;
    border-radius: 9999px;
    transition: color 0.2s ease, background 0.2s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: #e2e8e4;
    background: rgba(57, 56, 62, 0.5);
  }

  .nav-link.active {
    color: #adcebe;
    background: rgba(45, 74, 62, 0.35);
  }

  @media (max-width: 480px) {
    .nav-link {
      font-size: 0.8rem;
      padding: 0.4rem 0.7rem;
    }
  }
</style>
