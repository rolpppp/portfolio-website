---
import TopoBackground from "./TopoBackground.astro";

// Confirmed with Rolf 2026-07-02: Honorable Mention (top 6 of 70+ teams
// across Southeast Asia) at the APRU Tech Policy Hackathon 2025, Google
// Bangkok — leads the hackathon metric; the Top-5 regional finish (Stealth)
// lives in Journey/Expeditions. "7" matches the Featured Expeditions count.
const METRICS = [
  { value: "3+", label: "Years as DOST-SEI Scholar" },
  { value: "7", label: "Projects Shipped" },
  { value: "Top 6", label: "APRU Int'l Hackathon · 70+ Teams" },
  { value: "2", label: "Leadership Roles Held" },
];
---

<section id="home" class="relative isolate overflow-hidden bg-paper px-6 pt-40 pb-24 md:px-12 lg:px-20">
  <TopoBackground />

  <div class="relative z-10 mx-auto grid max-w-6xl grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-8">
    <div class="lg:col-span-8">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-ink/70">
        Field Guide · Ed. 01 · 11.2543°N 125.0000°E
      </p>

      <h1 class="group relative mt-6 inline-block font-display text-[clamp(3rem,9vw,7rem)] leading-[0.92] font-light tracking-tight text-ink">
        Rolf Garces
        <span
          class="pointer-events-none absolute left-0 -bottom-2 translate-y-full font-mono text-sm tracking-[0.2em] text-ocean opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-[calc(100%+0.5rem)]"
          aria-hidden="true"
        >
          11.2543°N · 125.0000°E — TACLOBAN CITY
        </span>
      </h1>

      <p class="mt-8 max-w-2xl font-sans text-lg font-light text-ink/70 md:text-xl">
        Computer Science Student · Software Engineer · Researcher · Builder
      </p>

      <p class="mt-6 max-w-xl font-sans text-base leading-relaxed text-ink/80 md:text-lg">
        Building technology that helps people navigate the real world through software, research, and entrepreneurship.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-5">
        <a
          href="#journey"
          class="inline-flex items-center justify-center rounded-sm bg-ocean px-7 py-3.5 font-sans text-sm font-medium tracking-wide text-paper transition-colors hover:bg-ink"
        >
          Explore the Journey
        </a>
        <a
          href="#projects"
          class="inline-flex items-center justify-center rounded-sm border border-ink/20 px-7 py-3.5 font-sans text-sm font-medium tracking-wide text-ink transition-colors hover:border-ink hover:text-ocean"
        >
          View Projects
        </a>
      </div>
    </div>

    <figure class="lg:col-span-3 lg:col-start-10 lg:self-center">
      <div class="relative mx-auto aspect-[4/5] w-56 max-w-full overflow-hidden rounded-sm border border-ink/15 bg-paper-alt/60 lg:w-full">
        <img
          src="/assets/images/profile.png"
          alt="Rolf Garces"
          class="absolute inset-0 h-full w-full object-cover object-[center_10%]"
        />
        <span class="absolute left-2 top-2 h-4 w-4 border-l border-t border-gold/80" aria-hidden="true"></span>
        <span class="absolute right-2 top-2 h-4 w-4 border-r border-t border-gold/80" aria-hidden="true"></span>
        <span class="absolute bottom-2 right-2 h-4 w-4 border-b border-r border-gold/80" aria-hidden="true"></span>
        <span class="absolute bottom-2 left-2 h-4 w-4 border-b border-l border-gold/80" aria-hidden="true"></span>
      </div>
      <figcaption class="mt-3 text-center font-mono text-[10px] tracking-[0.2em] text-ink/40 uppercase lg:text-left">
        FIG. 00 · Expedition Lead
      </figcaption>
    </figure>
  </div>

  <div class="relative z-10 mx-auto mt-24 grid max-w-6xl grid-cols-2 gap-x-8 gap-y-10 border-t border-ink/10 pt-12 md:grid-cols-4 justify-items-center">
    {METRICS.map((metric) => (
      <div class="text-center">
        <p class="font-display text-4xl font-light text-ink md:text-5xl">{metric.value}</p>
        <p class="mt-2 font-mono text-[11px] tracking-[0.14em] text-ink/70 uppercase">{metric.label}</p>
      </div>
    ))}
  </div>
</section>

<script>
  import { initMotion, prefersReducedMotion } from "../lib/motion";

  const hero = document.querySelector<HTMLElement>("#home");
  const topo = document.querySelector<HTMLElement>("[data-topo-bg]");

  if (hero && topo && !prefersReducedMotion()) {
    const { gsap, ScrollTrigger } = initMotion();
    gsap.to(topo, {
      yPercent: 12,
      ease: "none",
      scrollTrigger: {
        trigger: hero,
        start: "top top",
        end: "bottom top",
        scrub: true,
      },
    });
  }
</script>
