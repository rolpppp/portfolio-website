---
// Research & Innovation — field-notebook / scientific-poster identity
// (design-brief.md §4). Warm Ivory surface with a faint graph-paper grid;
// each research area is a catalogued figure card: line-drawn diagram, mono
// labels, and cross-references to the numbered Featured Expeditions. The only
// "data" shown is real data (status, refs) — no decorative fake charts.
// Weighted equal to Featured Expeditions: same header scale, same rhythm.
import { getCollection } from "astro:content";

const areas = (await getCollection("research")).sort(
  (a, b) => a.data.order - b.data.order
);

// Status marks: dot color is graphical info (≥3:1 on ivory), label is ink.
const STATUS_DOT: Record<string, string> = {
  Active: "bg-moss",
  Ongoing: "bg-gold",
  Exploring: "bg-ocean",
};

// Line-drawn notebook figures, one per research area. Stroke inherits the
// card's ink tone; the single gold mark per figure is the system's rare
// marking color doing its one job.
const FIGURES: Record<string, string> = {
  vision: `
    <path d="M10 22 V10 H24" /><path d="M96 10 H110 V22" />
    <path d="M110 50 V62 H96" /><path d="M24 62 H10 V50" />
    <rect x="36" y="24" width="48" height="26" stroke-dasharray="4 3" />
    <circle cx="60" cy="37" r="3" fill="var(--color-gold)" stroke="none" />`,
  ai: `
    <circle cx="60" cy="36" r="9" />
    <circle cx="60" cy="36" r="22" stroke-dasharray="3 5" />
    <line x1="60" y1="14" x2="60" y2="6" /><line x1="82" y1="36" x2="94" y2="36" />
    <line x1="60" y1="58" x2="60" y2="66" /><line x1="38" y1="36" x2="26" y2="36" />
    <circle cx="60" cy="36" r="2.5" fill="var(--color-gold)" stroke="none" />`,
  ml: `
    <circle cx="20" cy="52" r="2.5" fill="currentColor" stroke="none" />
    <circle cx="36" cy="44" r="2.5" fill="currentColor" stroke="none" />
    <circle cx="50" cy="47" r="2.5" fill="currentColor" stroke="none" />
    <circle cx="66" cy="32" r="2.5" fill="currentColor" stroke="none" />
    <circle cx="84" cy="27" r="2.5" fill="currentColor" stroke="none" />
    <circle cx="98" cy="18" r="2.5" fill="currentColor" stroke="none" />
    <path d="M12 58 L108 12" stroke-dasharray="5 4" />
    <circle cx="66" cy="32" r="5" stroke="var(--color-gold)" />`,
  graph: `
    <line x1="24" y1="50" x2="48" y2="20" /><line x1="48" y1="20" x2="76" y2="48" />
    <line x1="76" y1="48" x2="98" y2="22" /><line x1="24" y1="50" x2="60" y2="60" />
    <line x1="60" y1="60" x2="76" y2="48" /><line x1="48" y1="20" x2="98" y2="22" />
    <circle cx="24" cy="50" r="5" fill="var(--color-gold)" stroke="none" />
    <circle cx="48" cy="20" r="5" fill="currentColor" stroke="none" />
    <circle cx="76" cy="48" r="5" fill="var(--color-gold)" stroke="none" />
    <circle cx="98" cy="22" r="5" fill="none" />
    <circle cx="60" cy="60" r="5" fill="none" />`,
  optimization: `
    <path d="M12 12 C 30 56, 44 62, 60 60 C 78 58, 94 42, 108 14" />
    <line x1="60" y1="60" x2="60" y2="68" stroke-dasharray="2 3" />
    <circle cx="60" cy="60" r="3" fill="var(--color-gold)" stroke="none" />`,
  parsing: `
    <line x1="12" y1="24" x2="42" y2="24" /><line x1="12" y1="34" x2="36" y2="34" />
    <line x1="12" y1="44" x2="40" y2="44" />
    <path d="M52 34 H70 M70 34 l-5 -4 M70 34 l-5 4" />
    <path d="M84 18 h-6 v36 h6" /><path d="M104 18 h6 v36 h-6" />
    <circle cx="90" cy="30" r="2" fill="currentColor" stroke="none" />
    <circle cx="98" cy="30" r="2" fill="currentColor" stroke="none" />
    <circle cx="90" cy="42" r="2" fill="var(--color-gold)" stroke="none" />`,
  systems: `
    <rect x="14" y="14" width="30" height="20" />
    <rect x="14" y="42" width="30" height="20" />
    <rect x="60" y="28" width="30" height="20" stroke="var(--color-gold)" />
    <line x1="44" y1="24" x2="60" y2="34" /><line x1="44" y1="52" x2="60" y2="42" />
    <line x1="90" y1="38" x2="106" y2="38" stroke-dasharray="3 3" />`,
};
---

<section id="research" class="notebook-grid relative bg-paper-alt px-6 py-32 md:px-12 md:py-40 lg:px-20">
  <div class="mx-auto max-w-6xl">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-ink/70">
        Field Notes · {String(areas.length).padStart(2, "0")} Research Areas
      </p>
      <h2 class="mt-6 font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[0.95] font-light tracking-tight text-ink">
        Research &amp; Innovation
      </h2>
      <p class="mt-8 max-w-xl font-sans text-base leading-relaxed text-ink/80 md:text-lg">
        Discovery is half the expedition. These are the areas under active
        study — each one feeding directly back into something built.
      </p>
    </header>

    <div class="mt-16 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {areas.map((area, i) => (
        <article
          data-research-card
          class={`flex flex-col rounded-sm border border-ink/10 bg-paper p-6 transition-colors hover:border-ink/30 md:p-7 ${i === 0 ? "md:col-span-2 lg:col-span-3 lg:flex-row lg:items-center lg:gap-12" : ""}`}
        >
          <div class={i === 0 ? "lg:order-2 lg:w-72 lg:shrink-0" : ""}>
            <svg
              viewBox="0 0 120 72"
              class="h-24 w-full text-ink/50"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              aria-hidden="true"
              focusable="false"
              set:html={FIGURES[area.data.figure]}
            />
            <p class="mt-2 text-center font-mono text-[10px] tracking-[0.2em] text-ink/40 uppercase">
              FIG. R-{String(i + 1).padStart(2, "0")}
            </p>
          </div>

          <div class={`mt-5 flex flex-1 flex-col ${i === 0 ? "lg:order-1 lg:mt-0" : ""}`}>
            <div class="flex items-baseline justify-between gap-4">
              <p class="font-mono text-[11px] tracking-[0.2em] text-ink/60 uppercase">
                R-{String(i + 1).padStart(2, "0")}
              </p>
              <p class="flex items-center gap-2 font-mono text-[10px] tracking-[0.16em] text-ink/60 uppercase">
                <span class={`inline-block h-2 w-2 rounded-full ${STATUS_DOT[area.data.status]}`} aria-hidden="true"></span>
                {area.data.status}
              </p>
            </div>
            <h3 class="mt-3 font-display text-2xl font-light tracking-tight text-ink md:text-[1.65rem]">
              {area.data.title}
            </h3>
            <p class="mt-3 flex-1 font-sans text-sm leading-relaxed text-ink/70">
              {area.data.description}
            </p>
            <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-1.5 border-t border-ink/10 pt-4" aria-label="Related work">
              {area.data.refs.map((ref) => (
                <li class="font-mono text-[10px] tracking-[0.14em] text-ocean uppercase">
                  {ref}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Faint graph-paper grid — the section's field-notebook ground. Kept at
     near-background contrast so it reads as texture, not decoration. */
  .notebook-grid {
    background-image:
      linear-gradient(to right, rgba(18, 53, 36, 0.045) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(18, 53, 36, 0.045) 1px, transparent 1px);
    background-size: 28px 28px;
  }
</style>

<script>
  import { initMotion, prefersReducedMotion } from "../lib/motion";

  // Quiet one-time fade-up per card — same restraint as the other sections.
  if (!prefersReducedMotion()) {
    const { gsap } = initMotion();
    gsap.utils.toArray<HTMLElement>("[data-research-card]").forEach((el) => {
      gsap.from(el, {
        y: 24,
        opacity: 0,
        duration: 0.7,
        ease: "power2.out",
        scrollTrigger: { trigger: el, start: "top 88%" },
      });
    });
  }
</script>
