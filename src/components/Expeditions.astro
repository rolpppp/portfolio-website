---
// Featured Expeditions — projects as case studies (design-brief.md §3,
// redesigned per design-review.md §E/§E2). Composition deliberately breaks
// the Journey-clone card anatomy: one isolated featured card (Von Restorff —
// the anchor credential), then compact hairline rows. Per-card scan design:
// information-bearing `context` eyebrow at the first-fixation point, a
// numeral-first `metric` on the right rail (the F-pattern dead zone), the
// Outcome visible while collapsed, and a labeled FIELD REPORT signifier
// instead of a bare "+". Stack tags are demoted to a plain mono line.
import { getCollection } from "astro:content";
import fs from "node:fs";
import path from "node:path";

const expeditions = (await getCollection("expeditions")).sort(
  (a, b) => a.data.order - b.data.order
);
const [featured, ...rest] = expeditions;

// Per-project screenshots live in public/assets/images/expeditions/<id>/
// (id = the content file's name). Drop images in a folder and the build
// picks them up, sorted by filename — no frontmatter needed. Cards with 2+
// images auto-rotate client-side (see the slideshow script below); empty
// folders keep the labeled placeholder frame.
const IMAGE_ROOT = path.join(process.cwd(), "public/assets/images/expeditions");
const IMAGE_EXT = /\.(png|jpe?g|webp|avif|gif)$/i;
function projectImages(id: string, title: string) {
  const dir = path.join(IMAGE_ROOT, id);
  if (!fs.existsSync(dir)) return [];
  return fs
    .readdirSync(dir)
    .filter((f) => IMAGE_EXT.test(f))
    .sort()
    .map((f, i) => ({
      src: `/assets/images/expeditions/${id}/${encodeURIComponent(f)}`,
      alt: `${title} — screenshot ${i + 1}`,
    }));
}
const featuredImages = projectImages(featured.id, featured.data.title);
const restImages = rest.map((e) => projectImages(e.id, e.data.title));

// Expanded field-report rubric. Outcome is NOT here — it renders collapsed.
const FIELDS = [
  { key: "mission", label: "Mission" },
  { key: "problem", label: "Problem" },
  { key: "approach", label: "Approach" },
  { key: "lessons", label: "Lessons Learned" },
] as const;

const monoLink =
  "font-mono text-[11px] tracking-[0.16em] text-ocean uppercase underline decoration-ocean/30 underline-offset-4 transition-colors hover:text-ink hover:decoration-ink/30";
---

<section id="projects" class="relative isolate overflow-hidden bg-paper px-6 py-32 md:px-12 md:py-40 lg:px-20">
  {/* Ground: a faint plotted traverse — one dashed polyline with waypoint
      ticks drifting down the section's right side. Near-background ink,
      texture only (the section's equivalent of Research's graph paper). */}
  <svg
    class="pointer-events-none absolute inset-0 -z-10 h-full w-full"
    viewBox="0 0 1440 2000"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M 1180 -60 L 1264 240 L 1052 520 L 1244 820 L 1020 1140 L 1282 1460 L 1096 1780 L 1220 2100"
      fill="none"
      stroke="var(--color-ink)"
      stroke-width="1.5"
      stroke-dasharray="2 7"
      stroke-linecap="round"
      opacity="0.06"
    ></path>
    {[
      [1264, 240],
      [1052, 520],
      [1244, 820],
      [1020, 1140],
      [1282, 1460],
      [1096, 1780],
    ].map(([x, y]) => (
      <circle cx={x} cy={y} r="4" fill="none" stroke="var(--color-ink)" stroke-width="1.5" opacity="0.08" />
    ))}
  </svg>

  <div class="mx-auto max-w-6xl">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-ink/70">
        Field Reports
      </p>
      <h2 class="mt-6 font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[0.95] font-light tracking-tight text-ink">
        Featured Expeditions
      </h2>
      <p class="mt-8 max-w-xl font-sans text-base leading-relaxed text-ink/80 md:text-lg">
        Each project written up as a case study: the problem, the approach,
        and what it changed.
      </p>
    </header>

    {/* Traverse spine (desktop): the dashed trail down the left gutter with
        a survey pin per report — Journey's waypoint language carried into
        the projects. Gold pin = the featured expedition. */}
    <div class="relative mt-16 lg:pl-14">
      <span
        class="absolute bottom-6 left-[5px] top-6 hidden w-0 border-l border-dashed border-ink/25 lg:block"
        aria-hidden="true"
      ></span>

    {/* Featured card — the anchor credential, visually isolated. */}
    <details
      data-expedition
      class="group relative rounded-sm border border-ink/20 bg-paper-alt/60 open:border-ink/40"
    >
      <summary class="grid cursor-pointer list-none gap-8 px-6 py-8 md:px-10 md:py-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,20rem)] [&::-webkit-details-marker]:hidden">
        <span
          class="absolute left-[-51px] top-[46px] hidden h-3 w-3 -translate-x-1/2 rounded-full border-2 border-gold bg-gold/25 lg:block"
          aria-hidden="true"
        ></span>
        <div>
          <p class="font-mono text-[11px] tracking-[0.2em] text-ink/60 uppercase">
            {featured.data.context}
          </p>
          <h3 class="mt-3 font-display text-3xl font-light tracking-tight text-ink md:text-4xl">
            {featured.data.title}
          </h3>
          <p class="mt-3 max-w-xl font-sans text-sm leading-relaxed text-ink/70 md:text-base">
            {featured.data.summary}
          </p>

          <p class="mt-5 max-w-xl border-l-2 border-moss/60 pl-4 font-sans text-sm leading-relaxed text-ink/90 md:text-base">
            <span class="font-mono text-[10px] tracking-[0.2em] text-ink/50 uppercase">Outcome — </span>
            {featured.data.outcome}
          </p>

          <p class="mt-4 font-mono text-[10px] tracking-[0.14em] text-ink/50 uppercase">
            {featured.data.stack.join(", ")}
          </p>

          <p class="mt-6 flex flex-wrap items-baseline gap-x-6 gap-y-2">
            {featured.data.repo && (
              <a href={featured.data.repo} target="_blank" rel="noopener noreferrer" class={monoLink}>Code ↗</a>
            )}
            {featured.data.demo && (
              <a href={featured.data.demo} target="_blank" rel="noopener noreferrer" class={monoLink}>Live site ↗</a>
            )}
            {featured.data.linkNote && (
              <span class="font-mono text-[10px] tracking-[0.14em] text-ink/45 uppercase">{featured.data.linkNote}</span>
            )}
            <span class="font-mono text-[10px] tracking-[0.16em] text-ink/45 uppercase">
              Field report
              <span class="ml-1 inline-block transition-transform duration-300 group-open:rotate-45" aria-hidden="true">+</span>
            </span>
          </p>
        </div>

        <div class="flex flex-col gap-5 lg:pt-1">
          {/* The card's single loudest element — the numeral. */}
          <div>
            <p class="font-display text-3xl font-light tracking-tight text-ink md:text-4xl lg:text-right">
              {featured.data.metric}
            </p>
            <p class="mt-1.5 font-mono text-[10px] tracking-[0.16em] text-ink/45 uppercase lg:text-right">
              {featured.data.coords}
            </p>
          </div>
          <figure>
            {featuredImages.length > 0 ? (
              <div class="relative aspect-[4/3] w-full overflow-hidden rounded-sm border border-ink/15" data-slideshow>
                {featuredImages.map((img, k) => (
                  <img
                    src={img.src}
                    alt={img.alt}
                    loading="lazy"
                    decoding="async"
                    data-slide
                    class={`absolute inset-0 h-full w-full object-cover transition-opacity duration-700 ${k === 0 ? "opacity-100" : "opacity-0"}`}
                  />
                ))}
              </div>
            ) : (
              <div class="flex aspect-[4/3] w-full items-center justify-center rounded-sm border border-dashed border-ink/25 bg-paper">
                <span class="font-mono text-[10px] tracking-[0.2em] text-ink/40 uppercase">Screenshot pending</span>
              </div>
            )}
            <figcaption class="mt-2 font-mono text-[10px] tracking-[0.16em] text-ink/45 uppercase lg:text-right">
              FIG. E-01 {featuredImages.length > 0 ? `· ${featured.data.title}` : "· placeholder — drop captures in the images folder"}
              {featuredImages.length > 1 && <span data-slide-counter>{` · 1/${featuredImages.length}`}</span>}
            </figcaption>
          </figure>
        </div>
      </summary>

      <div class="border-t border-ink/10 px-6 pb-10 pt-6 md:px-10">
        <div class="border-l border-ink/15 pl-5 md:pl-6">
          <p class="font-mono text-[10px] tracking-[0.2em] text-ink/50 uppercase">
            Report E-01 — Filed from {featured.data.location}
          </p>
          <dl class="mt-6 grid gap-x-12 gap-y-6 md:grid-cols-2">
            {FIELDS.map((field) => (
              <div>
                <dt class="font-mono text-[10px] tracking-[0.2em] text-ink/50 uppercase">{field.label}</dt>
                <dd class="mt-2 font-sans text-sm leading-relaxed text-ink/80">{featured.data[field.key]}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </details>

    {/* Compact rows — hairline dividers, no card chrome. */}
    <div class="mt-14">
      {rest.map((exp, i) => (
        <details data-expedition class="group relative border-b border-ink/15 first:border-t first:border-t-ink/15">
          <summary class="grid cursor-pointer list-none gap-x-10 gap-y-4 py-8 md:grid-cols-[minmax(0,1fr)_minmax(0,12rem)] [&::-webkit-details-marker]:hidden">
            <span
              class="absolute left-[-51px] top-[38px] hidden h-2.5 w-2.5 -translate-x-1/2 rounded-full border-2 border-ink/40 bg-paper lg:block"
              aria-hidden="true"
            ></span>
            <div>
              <p class="font-mono text-[11px] tracking-[0.2em] text-ink/60 uppercase">
                {exp.data.context}
              </p>
              <h3 class="mt-2 font-display text-2xl font-light tracking-tight text-ink md:text-3xl">
                {exp.data.title}
              </h3>
              <p class="mt-2 max-w-xl font-sans text-sm leading-relaxed text-ink/70 md:text-base">
                {exp.data.summary}
              </p>

              <p class="mt-4 max-w-xl border-l-2 border-moss/60 pl-4 font-sans text-sm leading-relaxed text-ink/90">
                <span class="font-mono text-[10px] tracking-[0.2em] text-ink/50 uppercase">Outcome — </span>
                {exp.data.outcome}
              </p>

              <p class="mt-3 font-mono text-[10px] tracking-[0.14em] text-ink/50 uppercase">
                {exp.data.stack.join(", ")}
              </p>

              {(exp.data.repo || exp.data.demo || exp.data.linkNote) && (
                <p class="mt-4 flex flex-wrap items-baseline gap-x-6 gap-y-2">
                  {exp.data.repo && (
                    <a href={exp.data.repo} target="_blank" rel="noopener noreferrer" class={monoLink}>Code ↗</a>
                  )}
                  {exp.data.demo && (
                    <a href={exp.data.demo} target="_blank" rel="noopener noreferrer" class={monoLink}>Live site ↗</a>
                  )}
                  {exp.data.linkNote && (
                    <span class="font-mono text-[10px] tracking-[0.14em] text-ink/45 uppercase">{exp.data.linkNote}</span>
                  )}
                </p>
              )}
            </div>

            <div class="flex items-baseline justify-between gap-4 md:flex-col md:items-end md:justify-start md:gap-3 md:text-right">
              <p class="font-display text-xl font-light tracking-tight text-ink md:text-2xl">
                {exp.data.metric}
              </p>
              <p class="hidden font-mono text-[10px] tracking-[0.16em] text-ink/45 uppercase md:block">
                {exp.data.coords}
              </p>
              <span class="font-mono text-[10px] tracking-[0.16em] text-ink/45 uppercase">
                Field report
                <span class="ml-1 inline-block transition-transform duration-300 group-open:rotate-45" aria-hidden="true">+</span>
              </span>
            </div>
          </summary>

          <div class="border-l border-ink/15 pb-9 pl-5 md:pl-6">
            <p class="font-mono text-[10px] tracking-[0.2em] text-ink/50 uppercase">
              Report E-{String(i + 2).padStart(2, "0")} — Filed from {exp.data.location}
            </p>
            <div class="mt-6 grid gap-8 md:grid-cols-[minmax(0,15rem)_1fr]">
            <figure>
              {restImages[i].length > 0 ? (
                <div class="relative aspect-[4/3] w-full overflow-hidden rounded-sm border border-ink/15" data-slideshow>
                  {restImages[i].map((img, k) => (
                    <img
                      src={img.src}
                      alt={img.alt}
                      loading="lazy"
                      decoding="async"
                      data-slide
                      class={`absolute inset-0 h-full w-full object-cover transition-opacity duration-700 ${k === 0 ? "opacity-100" : "opacity-0"}`}
                    />
                  ))}
                </div>
              ) : (
                <div class="flex aspect-[4/3] w-full items-center justify-center rounded-sm border border-dashed border-ink/25 bg-paper-alt/60">
                  <span class="font-mono text-[10px] tracking-[0.2em] text-ink/40 uppercase">Screenshot pending</span>
                </div>
              )}
              <figcaption class="mt-2 font-mono text-[10px] tracking-[0.16em] text-ink/45 uppercase">
                FIG. E-{String(i + 2).padStart(2, "0")} {restImages[i].length > 0 ? `· ${exp.data.title}` : "· placeholder — drop captures in the images folder"}
                {restImages[i].length > 1 && <span data-slide-counter>{` · 1/${restImages[i].length}`}</span>}
              </figcaption>
            </figure>
            <dl class="grid content-start gap-x-12 gap-y-6 md:grid-cols-2">
              {FIELDS.map((field) => (
                <div>
                  <dt class="font-mono text-[10px] tracking-[0.2em] text-ink/50 uppercase">{field.label}</dt>
                  <dd class="mt-2 font-sans text-sm leading-relaxed text-ink/80">{exp.data[field.key]}</dd>
                </div>
              ))}
            </dl>
            </div>
          </div>
        </details>
      ))}
    </div>
    </div>

    {/* Ongoing and smaller work (e.g. AcadSort, a desktop academic-file
        organizer) lives on GitHub rather than getting a padded card here. */}
    <p class="mt-12 flex flex-wrap items-baseline gap-x-4 gap-y-2 lg:pl-14">
      <a
        href="https://github.com/rolpppp"
        target="_blank"
        rel="noopener noreferrer"
        class={monoLink}
      >
        See more on GitHub ↗
      </a>
      <span class="font-sans text-sm text-ink/60">
        including work in progress like AcadSort, a desktop app that auto-organizes academic files.
      </span>
    </p>
  </div>
</section>

<script>
  import { initMotion, prefersReducedMotion } from "../lib/motion";

  // Quiet one-time fade-up per card/row.
  if (!prefersReducedMotion()) {
    const { gsap } = initMotion();
    gsap.utils.toArray<HTMLElement>("[data-expedition]").forEach((el) => {
      gsap.from(el, {
        y: 24,
        opacity: 0,
        duration: 0.7,
        ease: "power2.out",
        scrollTrigger: { trigger: el, start: "top 88%" },
      });
    });
  }

  // Screenshot slideshows: crossfade to the next image every few seconds,
  // but only while the figure is actually on screen (closed <details> or
  // off-viewport figures never tick). Skipped entirely under
  // prefers-reduced-motion — those visitors see the first image, static.
  if (!prefersReducedMotion()) {
    const ROTATE_MS = 4000;
    document.querySelectorAll<HTMLElement>("[data-slideshow]").forEach((box) => {
      const slides = Array.from(box.querySelectorAll<HTMLElement>("[data-slide]"));
      if (slides.length < 2) return;
      const counter = box.closest("figure")?.querySelector<HTMLElement>("[data-slide-counter]") ?? null;
      let current = 0;
      let timer: number | undefined;

      const advance = () => {
        slides[current].classList.replace("opacity-100", "opacity-0");
        current = (current + 1) % slides.length;
        slides[current].classList.replace("opacity-0", "opacity-100");
        if (counter) counter.textContent = ` · ${current + 1}/${slides.length}`;
      };

      new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting && timer === undefined) {
              timer = window.setInterval(advance, ROTATE_MS);
            } else if (!entry.isIntersecting && timer !== undefined) {
              window.clearInterval(timer);
              timer = undefined;
            }
          }
        },
        { threshold: 0.2 }
      ).observe(box);
    });
  }
</script>
