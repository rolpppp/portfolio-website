---
// Featured Expeditions — projects as case studies (design-brief.md §3).
// Same disclosure pattern as Journey's travel logs, deliberately calmer:
// paper background, quiet bordered cards, no route/curve visual — the
// signature moment stays in the Journey section.
import { getCollection } from "astro:content";

const expeditions = (await getCollection("expeditions")).sort(
  (a, b) => a.data.order - b.data.order
);

// Expanded case-study fields, in the brief's order (stack lives on the
// collapsed card as tags).
const FIELDS = [
  { key: "mission", label: "Mission" },
  { key: "problem", label: "Problem" },
  { key: "approach", label: "Approach" },
  { key: "outcome", label: "Outcome" },
] as const;
---

<section id="projects" class="relative bg-paper px-6 py-32 md:px-12 md:py-40 lg:px-20">
  <div class="mx-auto max-w-6xl">
    <header class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-ink/70">
        Field Reports · {String(expeditions.length).padStart(2, "0")} Expeditions
      </p>
      <h2 class="mt-6 font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[0.95] font-light tracking-tight text-ink">
        Featured Expeditions
      </h2>
      <p class="mt-8 max-w-xl font-sans text-base leading-relaxed text-ink/80 md:text-lg">
        Projects written up as case studies, not repo listings — each one a
        problem explored, an approach chosen, and a lesson carried forward.
      </p>
    </header>

    <div class="mt-16 space-y-5">
      {expeditions.map((exp, i) => (
        <details
          data-expedition
          class="group rounded-sm border border-ink/10 bg-paper-alt/50 transition-colors hover:border-ink/30 open:border-ink/30"
        >
          <summary class="flex cursor-pointer list-none items-start justify-between gap-6 px-6 py-6 md:px-8 [&::-webkit-details-marker]:hidden">
            <div>
              <p class="font-mono text-[11px] tracking-[0.2em] text-ink/60 uppercase">
                Expedition {String(i + 1).padStart(2, "0")}
              </p>
              <h3 class="mt-2 font-display text-2xl font-light tracking-tight text-ink md:text-3xl">
                {exp.data.title}
              </h3>
              <p class="mt-2 max-w-xl font-sans text-sm leading-relaxed text-ink/70 md:text-base">
                {exp.data.summary}
              </p>
              <ul class="mt-4 flex flex-wrap gap-2" aria-label="Technology stack">
                {exp.data.stack.map((tech) => (
                  <li class="rounded-sm border border-ink/15 px-2.5 py-1 font-mono text-[10px] tracking-[0.12em] text-ink/70 uppercase">
                    {tech}
                  </li>
                ))}
              </ul>
            </div>
            <span
              class="mt-1 shrink-0 font-mono text-lg leading-none text-ink/40 transition-transform duration-300 group-open:rotate-45"
              aria-hidden="true"
            >+</span>
          </summary>

          <div class="border-t border-ink/10 px-6 pb-8 pt-6 md:px-8">
            <dl class="grid gap-x-12 gap-y-6 md:grid-cols-2">
              {FIELDS.map((field) => (
                <div>
                  <dt class="font-mono text-[10px] tracking-[0.2em] text-ink/50 uppercase">
                    {field.label}
                  </dt>
                  <dd class="mt-2 font-sans text-sm leading-relaxed text-ink/80">
                    {exp.data[field.key]}
                  </dd>
                </div>
              ))}
              <div class="md:col-span-2">
                <dt class="font-mono text-[10px] tracking-[0.2em] text-ink/50 uppercase">
                  Lessons Learned
                </dt>
                <dd class="mt-2 max-w-2xl font-sans text-sm leading-relaxed text-ink/80">
                  {exp.data.lessons}
                </dd>
              </div>
            </dl>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  import { initMotion, prefersReducedMotion } from "../lib/motion";

  // Quiet one-time fade-up per card — same restraint as Journey's checkpoints.
  if (!prefersReducedMotion()) {
    const { gsap } = initMotion();
    gsap.utils.toArray<HTMLElement>("[data-expedition]").forEach((el) => {
      gsap.from(el, {
        y: 24,
        opacity: 0,
        duration: 0.7,
        ease: "power2.out",
        scrollTrigger: { trigger: el, start: "top 88%" },
      });
    });
  }
</script>
