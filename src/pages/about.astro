---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    role: 'Campus Ambassador',
    org: 'DEVCON Philippines',
    location: 'UP Tacloban',
    period: 'May 2025 – Present',
    bullets: [
      "Represent the Philippines' largest community of developers within the university, organizing tech events and workshops to foster local talent.",
      'Facilitate partnerships between the academe and professional tech communities to bridge the gap between theory and industry practice.',
    ],
  },
  {
    role: 'Programming Tutor',
    org: 'BrainBox',
    location: 'Tacloban City, Leyte',
    period: 'Jan 2025 – Present',
    bullets: [
      'Mentor students in fundamental programming concepts (Java, Python), resulting in measurable improvements in academic performance and coding comprehension.',
      'Develop customized lesson plans and technical exercises to simplify complex algorithmic topics for beginners.',
    ],
  },
  {
    role: 'Vice President',
    org: 'UP Interactive Society',
    location: 'UP Tacloban',
    period: 'Aug 2024 – May 2025',
    bullets: [
      'Lead project management initiatives for the academic organization, overseeing event logistics and team coordination for the BSCS student body.',
      'Spearhead collaborative projects that enhance peer-to-peer technical learning and student engagement.',
    ],
  },
];

const skills = {
  Languages: ['Python', 'Java', 'JavaScript', 'SQL (PostgreSQL, MySQL)', 'Dart', 'HTML / CSS'],
  Frameworks: ['Flask', 'Flutter', 'TensorFlow', 'React (Basic)'],
  'Developer Tools': ['Git', 'GitHub', 'VS Code', 'IntelliJ', 'Docker'],
  Libraries: ['Pandas', 'NumPy', 'OpenCV', 'PyTorch'],
};
---

<Layout title="About" description="About Rolf Garces — CS Student, DOST Scholar, and builder from the University of the Philippines Tacloban.">

  <!-- =========================================
       BIO HERO
       ========================================= -->
  <section class="section bg-surface page-hero">
    <div class="glow-blob" style="width: 450px; height: 450px; top: -60px; right: -40px; opacity: 0.15;"></div>
    <div class="container">
      <p class="label-md section-eyebrow">About Me</p>
      <h1 class="display-lg page-title">Rolf Garces.</h1>
      <p class="body-lg bio-text">
        I'm a Computer Science student at the University of the Philippines Tacloban &mdash;
        DOST-SEI Scholar, my batch's Valedictorian, and someone who genuinely believes software
        can change things. I've spent the last few years building AI pipelines, backend APIs,
        and tools that solve real problems: from an automated crop damage assessment system
        presented at Google Bangkok, to a hackathon prototype built in 24 hours. When I'm not
        coding, I'm helping others learn &mdash; as a programming tutor and Campus Ambassador
        for DEVCON Philippines.
      </p>
    </div>
  </section>

  <!-- =========================================
       EDUCATION
       ========================================= -->
  <section class="section bg-surface-lowest">
    <div class="container">
      <p class="label-md section-eyebrow">Education</p>
      <h2 class="headline-md section-title">Where I've Studied</h2>

      <div class="edu-card glass-card">
        <div class="edu-header">
          <div>
            <h3 class="headline-sm edu-school">University of the Philippines Tacloban</h3>
            <p class="edu-degree body-lg">Bachelor of Science in Computer Science</p>
          </div>
          <div class="edu-meta">
            <span class="label-md">Tacloban City, Leyte</span>
            <span class="label-md">Exp. July 2027</span>
          </div>
        </div>

        <div class="edu-details">
          <div class="edu-awards">
            <p class="label-md edu-section-label">Awards</p>
            <div class="award-tags">
              <span class="tag">DOST-SEI Scholar (2023–Present)</span>
              <span class="tag">Batch Valedictorian (2023)</span>
            </div>
          </div>
          <div class="edu-courses">
            <p class="label-md edu-section-label">Relevant Coursework</p>
            <div class="course-tags">
              <span class="tag">Data Structures & Algorithms</span>
              <span class="tag">Object-Oriented Programming</span>
              <span class="tag">Database Management</span>
              <span class="tag">Automata Theory</span>
              <span class="tag">Software Engineering</span>
              <span class="tag">Artificial Intelligence</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================
       EXPERIENCE
       ========================================= -->
  <section class="section bg-surface">
    <div class="container">
      <p class="label-md section-eyebrow">Experience</p>
      <h2 class="headline-md section-title">Where I've Worked</h2>

      <div class="timeline">
        {experience.map((item, i) => (
          <article class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-header">
                <div>
                  <h3 class="headline-sm timeline-role">{item.role}</h3>
                  <p class="timeline-org body-lg">{item.org} &mdash; {item.location}</p>
                </div>
                <span class="label-md timeline-period">{item.period}</span>
              </div>
              <ul class="timeline-bullets">
                {item.bullets.map(b => <li class="body-lg bullet-item">{b}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- =========================================
       SKILLS
       ========================================= -->
  <section class="section bg-surface-lowest">
    <div class="container">
      <p class="label-md section-eyebrow">Technical Skills</p>
      <h2 class="headline-md section-title">What I Work With</h2>

      <div class="skills-grid">
        {Object.entries(skills).map(([category, items]) => (
          <div class="skill-category glass-card">
            <h3 class="label-md skill-label">{category}</h3>
            <div class="skill-tags">
              {items.map(s => <span class="tag">{s}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Page hero */
  .page-hero {
    position: relative;
    overflow: hidden;
    padding-top: 8rem;
    padding-bottom: 3rem;
  }

  .page-title {
    color: var(--on-surface);
    margin-bottom: 1.5rem;
  }

  .bio-text {
    max-width: 660px;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  /* Education */
  .edu-card {
    padding: 2rem 2.5rem;
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .edu-school {
    color: var(--on-surface);
    margin-bottom: 0.4rem;
  }

  .edu-degree {
    color: var(--primary);
  }

  .edu-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
  }

  .edu-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .edu-section-label {
    margin-bottom: 0.75rem;
  }

  .award-tags,
  .course-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-left: 2rem;
  }

  /* Vertical connecting line — using background gradient, not a border */
  .timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(to bottom, var(--primary-container), transparent);
    border-radius: 9999px;
  }

  .timeline-item {
    position: relative;
    padding-bottom: 3rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -2rem;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--primary);
    box-shadow: 0 0 12px rgba(173, 206, 190, 0.3);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .timeline-role {
    color: var(--on-surface);
    margin-bottom: 0.3rem;
  }

  .timeline-org {
    color: var(--primary);
    font-size: 0.9rem;
  }

  .timeline-period {
    white-space: nowrap;
  }

  .timeline-bullets {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .bullet-item {
    position: relative;
    padding-left: 1rem;
  }

  .bullet-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--outline-variant);
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .skill-category {
    padding: 1.5rem;
  }

  .skill-label {
    margin-bottom: 0.875rem;
    color: var(--primary);
  }

  .skill-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }

    .edu-meta {
      align-items: flex-start;
    }

    .timeline-period {
      display: none;
    }
  }
</style>
