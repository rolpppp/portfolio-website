---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- =========================================
       HERO
       ========================================= -->
  <section class="hero section bg-surface">
    <!-- Soft moonlight glow blobs -->
    <div class="glow-blob" style="width: 500px; height: 500px; top: -80px; right: -60px;"></div>
    <div class="glow-blob" style="width: 250px; height: 250px; bottom: 80px; left: -80px; opacity: 0.12;"></div>

    <div class="container">
      <div class="hero-content">
        <p class="label-md hero-eyebrow">Hello, I'm</p>
        <h1 class="display-lg hero-name">Rolf Garces.</h1>
        <p class="hero-tagline">CS Student &middot; Backend Engineer &middot; AI Builder</p>
        <p class="body-lg hero-desc">
          Studying Computer Science at the University of the Philippines Tacloban.
          I build AI pipelines, backend systems, and tools that solve real problems &mdash;
          from automated crop insurance platforms to hackathon prototypes.
        </p>
        <div class="hero-ctas">
          <a href="/projects" class="btn-primary">See my work</a>
          <a href="/about" class="btn-secondary">About me</a>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================
       SELECTED WORK
       ========================================= -->
  <section class="section bg-surface-lowest">
    <div class="container">
      <p class="label-md section-eyebrow">Selected Work</p>
      <h2 class="headline-md section-title">Projects</h2>

      <div class="projects-list">

        <article class="project-card glass-card">
          <div class="project-meta">
            <span class="label-md">01</span>
            <span class="label-md">Jul &ndash; Oct 2025</span>
          </div>
          <h3 class="headline-sm project-name">Project AIGRI</h3>
          <p class="body-lg">
            Automated crop insurance platform using drone imagery and computer vision.
            Architected the AI pipeline with ResNet-50, built a Flask RESTful API, and
            presented at Google Bangkok.
          </p>
          <div class="project-tags">
            <span class="tag">Python</span>
            <span class="tag">Flask</span>
            <span class="tag">OpenCV</span>
            <span class="tag">ResNet-50</span>
          </div>
        </article>

        <article class="project-card glass-card project-card--offset">
          <div class="project-meta">
            <span class="label-md">02</span>
            <span class="label-md">June 2025</span>
          </div>
          <h3 class="headline-sm project-name">Stealth</h3>
          <p class="body-lg">
            Hackathon prototype built at the rSCENE Regional Smart Communities Exposition.
            Led the team to 5th Place Overall. Delivered backend services and game logic
            under strict time constraints.
          </p>
          <div class="project-tags">
            <span class="tag">Python</span>
            <span class="tag">Flask</span>
            <span class="tag">PostgreSQL</span>
          </div>
        </article>

        <article class="project-card glass-card">
          <div class="project-meta">
            <span class="label-md">03</span>
            <span class="label-md">Feb &ndash; Apr 2025</span>
          </div>
          <h3 class="headline-sm project-name">General Laboratory IMS</h3>
          <p class="body-lg">
            Desktop application for UP Tacloban to manage laboratory equipment inventory.
            Engineered a normalized MySQL database and streamlined manual tracking across
            multiple departments.
          </p>
          <div class="project-tags">
            <span class="tag">Java</span>
            <span class="tag">MySQL</span>
            <span class="tag">JDBC</span>
          </div>
        </article>

      </div>

      <div class="view-all">
        <a href="/projects" class="btn-secondary">View all projects</a>
      </div>
    </div>
  </section>

  <!-- =========================================
       SKILLS
       ========================================= -->
  <section class="section bg-surface">
    <div class="container">
      <p class="label-md section-eyebrow">What I Work With</p>
      <h2 class="headline-md section-title">Skills</h2>

      <div class="skills-groups">
        <div class="skill-group">
          <h3 class="label-md skill-group-label">Languages</h3>
          <div class="skill-tags">
            <span class="tag">Python</span>
            <span class="tag">Java</span>
            <span class="tag">JavaScript</span>
            <span class="tag">SQL</span>
            <span class="tag">Dart</span>
            <span class="tag">HTML / CSS</span>
          </div>
        </div>

        <div class="skill-group">
          <h3 class="label-md skill-group-label">Frameworks & Tools</h3>
          <div class="skill-tags">
            <span class="tag">Flask</span>
            <span class="tag">Flutter</span>
            <span class="tag">TensorFlow</span>
            <span class="tag">React</span>
            <span class="tag">Git & GitHub</span>
            <span class="tag">Docker</span>
          </div>
        </div>

        <div class="skill-group">
          <h3 class="label-md skill-group-label">Libraries</h3>
          <div class="skill-tags">
            <span class="tag">Pandas</span>
            <span class="tag">NumPy</span>
            <span class="tag">OpenCV</span>
            <span class="tag">PyTorch</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-content {
    max-width: 680px;
    padding: 8rem 0 6rem;
    position: relative; /* sit above glow blobs */
    z-index: 1;
  }

  .hero-eyebrow {
    margin-bottom: 1rem;
  }

  .hero-name {
    color: var(--on-surface);
    margin-bottom: 1.25rem;
  }

  .hero-tagline {
    font-family: 'Manrope', sans-serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--primary);
    margin-bottom: 1.75rem;
    letter-spacing: 0.01em;
  }

  .hero-desc {
    max-width: 520px;
    margin-bottom: 2.5rem;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ---- Projects ---- */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .project-card {
    padding: 2rem 2.5rem;
    transition: transform 0.25s ease;
  }

  /* Staggered offset for alternating cards */
  .project-card--offset {
    margin-left: clamp(0px, 4vw, 3rem);
  }

  .project-card:hover {
    transform: translateY(-3px);
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .project-name {
    color: var(--on-surface);
    margin-bottom: 0.75rem;
  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .view-all {
    margin-top: 3rem;
  }

  /* ---- Skills ---- */
  .skills-groups {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .skill-group-label {
    margin-bottom: 0.875rem;
  }

  .skill-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
