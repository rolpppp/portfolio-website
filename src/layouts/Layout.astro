---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
}

const {
  title = "Rolf Genree Garces — Explorer, Engineer, Builder",
  description = "Building technology that helps people navigate the real world through software, research, and entrepreneurship.",
  url = new URL(Astro.url.pathname, Astro.site).href,
  image = new URL("/assets/images/profile.png", Astro.site).href,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f5f3ee" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0c1f15" />

    {/* Theme init — must run before first paint so there's no flash of the
        wrong theme. System preference by default; an explicit choice from
        the nav toggle (localStorage "theme") wins. While there's no stored
        choice, live system changes are followed. */}
    <script is:inline>
      (function () {
        var stored = null;
        try {
          stored = localStorage.getItem("theme");
        } catch (e) {}
        var mq = matchMedia("(prefers-color-scheme: dark)");
        var apply = function (t) {
          document.documentElement.dataset.theme = t;
        };
        apply(stored === "light" || stored === "dark" ? stored : mq.matches ? "dark" : "light");
        mq.addEventListener("change", function (e) {
          try {
            if (localStorage.getItem("theme")) return;
          } catch (err) {}
          apply(e.matches ? "dark" : "light");
        });
      })();
    </script>
    <link rel="canonical" href={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content="Rolf Genree Garces profile image" />
    <meta property="og:site_name" content="Rolf Genree Garces" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:site" content="@rolpppp" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,400&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-paper text-ink">
    <slot />
  </body>
</html>
